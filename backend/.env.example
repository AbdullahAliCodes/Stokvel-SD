# Copy this file to `.env` and fill in values. Never commit `.env`.

PORT=5000

SUPABASE_URL=https://your-project-ref.supabase.co

SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=

# Optional — document uploads bucket (see backend/src/index.js)
# SUPABASE_DOCUMENTS_BUCKET=stokvel-documents

FRONTEND_URL=http://localhost:5173

EMAIL_USER=

EMAIL_APP_PASSWORD=

PAYSTACK_SECRET_KEY=

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional override (default: SA policy rate series)
FRED_SA_POLICY_RATE_SERIES_ID=IRSTCB01ZAM156N
